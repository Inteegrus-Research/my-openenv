# Hugging Face Inference API (or any OpenAI-compatible endpoint)
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier (e.g., Qwen/Qwen2.5-7B-Instruct, meta-llama/Llama-3.2-3B-Instruct)
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Your Hugging Face token (or API key) – required for authenticated calls
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL where the environment server is running (default for local testing)
ENV_BASE_URL=http://127.0.0.1:7860